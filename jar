public class SkeletonClient implements ModInitializer {
    public static final String MOD_ID = "skeletonclient";
    public static final Logger LOG = LogManager.getLogger("SkeletonClient");
    public static final MinecraftClient MC = MinecraftClient.getInstance();

    // Global module registry
    private static final Map<String, Module> MODULES = new ConcurrentHashMap<>();

    @Override
    public void onInitialize() {
        LOG.info("SkeletonClient loading… fuck yeah");
        registerBuiltInModules();
        UIManager.init();
        EventBus.subscribe(PlayerTickEvent.class, SkeletonClient::onPlayerTick);
    }

    // ---------------------------
    // Module registration
    // ---------------------------
    private static void registerBuiltInModules() {
        // Core modules – you can add more via reflection or config
        registerModule(new ESPModule());
        registerModule(new KillAuraModule());
        registerModule(new ClickGuiModule());
        // ... add others as needed
    }

    public static void registerModule(Module module) {
        MODULES.put(module.getName().toLowerCase(Locale.ROOT), module);
        LOG.info("Registered module: {}", module.getName());
    }

    public static Optional<Module> getModule(String name) {
        return Optional.ofNullable(MODULES.get(name.toLowerCase(Locale.ROOT)));
    }

    // ---------------------------
    // Example tick handler
    // ---------------------------
    private static void onPlayerTick(PlayerTickEvent event) {
        for (Module m : MODULES.values()) {
            if (m.isEnabled()) {
                m.onTick(event);
            }
        }
    }

    // ---------------------------
    // Simple command system (via chat)
    // ---------------------------
    static {
        CommandRegistry.register("skeleton", (sender, args) -> {
            if (args.length == 0) {
                sender.sendMessage("§6SkeletonClient v1.0 §7| §fModules: " + MODULES.keySet());
                return;
            }
            String sub = args[0].toLowerCase(Locale.ROOT);
            switch (sub) {
                case "toggle":
                    if (args.length < 2) {
                        sender.sendMessage("§cUsage: /skeleton toggle <module>");
                        return;
                    }
                    getModule(args[1]).ifPresentOrElse(
                        m -> {
                            m.toggle();
                            sender.sendMessage("§a" + m.getName() + " toggled " + (m.isEnabled() ? "on" : "off"));
                        },
                        () -> sender.sendMessage("§cModule not found")
                    );
                    break;
                default:
                    sender.sendMessage("§cUnknown subcommand");
            }
        });
    }
}

