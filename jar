class EventBus {
    private static final Map<Class<?>, List<Consumer<?>>> LISTENERS = new HashMap<>();

    public static <T> void subscribe(Class<T> eventClass, Consumer<T> handler) {
        LISTENERS.computeIfAbsent(eventClass, k -> new ArrayList<>()).add(handler);
    }

    @SuppressWarnings("unchecked")
    public static <T> void post(T event) {
        List<Consumer<?>> handlers = LISTENERS.get(event.getClass());
        if (handlers != null) {
            for (Consumer<?> h : handlers) {
                ((Consumer<T>) h).accept(event);
            }
        }
    }
}

